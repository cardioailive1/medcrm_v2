# ── Core ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Comma-separated allowed origins for CORS (frontend origin in prod)
CORS_ORIGINS=http://localhost:3000

# ── Database ──────────────────────────────────────────
# On Render this is injected automatically from the managed Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medcrm?schema=public

# ── JWT ───────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900            # seconds (15 min)
JWT_REFRESH_TTL=2592000       # seconds (30 days)

# ── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs for each paid tier (create them in the Stripe dashboard)
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx
# Stripe Payment Links (public URLs from the Dashboard). Used by the app's upgrade buttons.
STRIPE_PAYMENT_LINK_PRO=https://buy.stripe.com/xxx
STRIPE_PAYMENT_LINK_ENTERPRISE=https://buy.stripe.com/xxx
# Where Stripe redirects after checkout / portal
APP_URL=http://localhost:3000

# ── Background jobs (automation layer) ────────────────
JOBS_ENABLED=true
